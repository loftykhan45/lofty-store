# Add this to your friend's existing Caddyfile (merge with whatever's
# already serving lofty.24-144-105-14.sslip.io — don't duplicate the site block).

lofty.24-144-105-14.sslip.io {
    root * /var/www/lofty-store
    file_server

    handle /deploy-hook {
        reverse_proxy 127.0.0.1:7777
    }
}
