# Merge into your friend's existing Caddyfile — REPLACE the previous
# file_server block for lofty.24-144-105-14.sslip.io with this reverse_proxy
# version. The site is no longer static files; Next.js needs a running Node
# process (managed by PM2, see deploy.sh) listening on 127.0.0.1:3000.

lofty.24-144-105-14.sslip.io {
    reverse_proxy 127.0.0.1:3000

    handle /deploy-hook {
        reverse_proxy 127.0.0.1:7777
    }
}
